<div class="container py-5">
    <div class="d-flex justify-content-between align-items-end mb-5 mb-5 animate-fade-in-up" style="animation-delay: 0.1s;">

        <div>
            <p class="text-uppercase small fw-semibold m-0" 
            style="color: #f18e3f; letter-spacing: 2px;">Acesso Administrativo</p>
            <h2 class="fw-light text-dark m-0" style="font-size: 2.2rem;">Gerenciar Produtos</h2>
        </div>

        <div>
            <a href="/admin/products/create" class="btn btn-premium-outline px-4 py-2 shadow-sm d-flex align-items-center gap-2">
                <i class="bi bi-plus-lg"></i> Adicionar Produto
            </a>
        </div>
    </div>

    {{!Produtos}}
    <div class="animate-fade-in-up" style="animation-delay: 0.2s;">
        {{#if products}}
            {{#each products}}
                <p>{{name}}</p>     {{!Melhorar}}
            {{/each}}
        {{else}}
            <div class="text-center text-secondary py-5 bg-light rounded">
                <i class="bi bi-box-seam fs-2 mb-3 d-block text-muted"></i>
                <p class="mb-0">Nenhum Produto encontrado</p>
            </div>
        {{/if}}
    </div>
    
</div>
<div class="container py-5">
  
  <div class="mb-5 animate-fade-in-up" style="animation-delay: 0.1s;">
    <p class="text-uppercase small fw-semibold m-0" style="color: #f18e3f; letter-spacing: 2px;">Gerenciamento Interno</p>
    <h2 class="fw-light text-dark m-0" style="font-size: 2.2rem;">
      <span class="brand-branca">Produtos</span> <span class="brand-jalecos">em Estoque</span>
    </h2>
  </div>

  {{> _errors}}
  {{> _flashMsg}}

  {{#if stock}}
    
    <div class="row g-4 animate-fade-in-up">
      
      {{#each stock}}
      <div class="col-6 col-sm-6 col-md-4 col-lg-3">
        
        <div class="card h-100 p-3 d-flex flex-column justify-content-between img-editorial-wrapper" style="border-radius: 4px;">
          
          <div>
            <div class="d-flex justify-content-between align-items-center mb-3">
              <span class="text-uppercase text-muted fw-semibold" style="font-size: 0.65rem; letter-spacing: 0.5px;">
                Linha: {{this.gender}}
              </span>
              
              {{#if this.active}}
                <span class="badge-status status-active" style="border-radius: 2px;">Ativo</span>
              {{else}}
                <span class="badge-status status-inactive" style="border-radius: 2px;">Inativo</span>
              {{/if}}
            </div>

            <h5 class="fw-bold text-dark m-0 text-truncate visual-product-name" title="{{this.name}}">
              {{this.name}}
            </h5>
            
            <p class="table-product-slug my-2">
              Ref: <span>{{this.slug}}</span>
            </p>
          </div>

          <div class="mt-3">
            <a href="/admin/stock/product/{{this._id}}" class="btn btn-premium w-100 d-flex align-items-center justify-content-center" style="height: 40px; font-size: 0.75rem;">
              Acessar estoque
            </a>
          </div>
          
        </div>
      </div>
      {{/each}}
      
    </div>

  {{else}}
    <div class="text-center py-5 bg-white border" style="border-color: #eadecc !important; border-radius: 4px;">
        <h4 class="fw-light text-dark">Nenhum Produto</h4>
        <p class="text-muted fw-light m-0">Cadastre produtos no sistema para gerenciar seus estoques.</p>
    </div>
  {{/if}}

</div>
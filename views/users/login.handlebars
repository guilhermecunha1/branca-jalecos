<div class="container py-5 d-flex justify-content-center align-items-center" style="min-height: 80vh;">
  
  <div class="col-12 col-sm-10 col-md-8 col-lg-5 animate-fade-in-up">

    <!-- Link Voltar ao Início -->
    <div class="mb-3">
      <a href="/" class=" btn-action-premium text-muted small text-decoration-none d-inline-flex align-items-center gap-1 fw-medium" style="font-size: 0.8rem;">
        &larr; Voltar ao início
      </a>
    </div>
    
    <!-- Card de Login (Usando o efeito de elevação sutil do seu CSS) -->
    <div class="card p-4 p-md-5 " style="border-radius: 4px;">
      
      <!-- Cabeçalho / Logo da Marca -->
      <div class="text-center mb-4">
        <h3 class="m-0 mb-1">
          <span class="brand-branca">BRANCA</span><span class="brand-jalecos"> Jalecos</span>
        </h3>
        <p class="text-muted small fw-light">Entre com suas credenciais para acessar o painel</p>
      </div>

      {{> _errors}}
      {{> _flashMsg}}

      <!-- Formulário de Login -->
      <form action="/users/login" method="POST">
        
        <!-- Campo: E-mail -->
        <div class="mb-3">
          <label for="email" class="form-label text-uppercase text-muted fw-semibold" style="font-size: 0.7rem; letter-spacing: 1px;">E-mail</label>
          <input type="email" 
                 id="email" 
                 name="email" 
                 class="form-control" 
                 required
                 autofocus
                 style="border-radius: 4px; border-color: #eadecc; height: 45px; font-size: 0.9rem;">
        </div>

        <!-- Campo: Senha -->
        <div class="mb-4">
          <div class="d-flex justify-content-between align-items-center mb-1">
            <label for="password" class="form-label text-uppercase text-muted fw-semibold m-0" style="font-size: 0.7rem; letter-spacing: 1px;">Senha</label>
            <a href="/forgot-password" class="text-muted small text-decoration-none" style="font-size: 0.75rem;">Esqueceu a senha?</a>
          </div>
          <input type="password" 
                 id="password" 
                 name="password" 
                 class="form-control"  
                 required
                 style="border-radius: 4px; border-color: #eadecc; height: 45px; font-size: 0.9rem;">
        </div>

        <!-- Botão de Ação usando seu .btn-premium -->
        <button type="submit" class="btn btn-premium w-100 mb-3" style="height: 48px;">
          Entrar no Sistema
        </button>

        <!-- Link para Cadastro -->
        <div class="text-center mt-4">
          <span class="text-muted small">Ainda não tem uma conta? </span>
          <a href="/users/register" class="btn-action-premium" style="font-size: 0.8rem !important;">
            Criar Conta
          </a>
        </div>

      </form>

    </div>
    
  </div>
</div>